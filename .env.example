# =============================================================================
# Database Engine — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#   nano .env
#
# This file IS committed to git (private repo, VPS-only).
# Default values are secure random strings generated for TIMESCALEDB_PASSWORD
# and SESSION_SECRET. Change ADMIN_PASSWORD before production use.
# =============================================================================

# ── Broker ─────────────────────────────────────────────────────────────────────
ACTIVE_BROKER=upstox  # Options: upstox, zerodha, angel_one

# ── Upstox Credentials ─────────────────────────────────────────────────────────
# Get these from: https://developer.upstox.com/
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_ACCESS_TOKEN=your_access_token_here
UPSTOX_REDIRECT_URI=https://database.masoomchoudhury.com/auth/upstox-callback

# Upstox Refresh Token — REQUIRED for automatic token refresh on expiry.
# Get this during the initial OAuth flow from the token response.
# Run `python upstox_auth.py` to perform the OAuth flow and retrieve both tokens.
# The engine will use this to automatically refresh access_token when it expires.
UPSTOX_REFRESH_TOKEN=your_refresh_token_here

# ── Supabase ───────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key_here

# Direct Postgres connection string for psycopg2 fallback (PostgREST bypass).
# Get from: Supabase Dashboard → Settings → Database → Connection string → URI
# Format: postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres

# ── Local TimescaleDB (optional — only needed if enabling local TimescaleDB) ─────
# IMPORTANT: Generate a new random password with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
TIMESCALEDB_USER=engine
TIMESCALEDB_PASSWORD=D281cpV6Qdt9AylOPFDG8jmjOVfXeLWGRr_APkC8x7UAZqwR90sOHuiaM7jYhfRb
TIMESCALEDB_NAME=trading_db
TIMESCALEDB_HOST=127.0.0.1
TIMESCALEDB_PORT=5432

# ── Web Admin Panel ─────────────────────────────────────────────────────────────
# CHANGE THIS PASSWORD before deploying to production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMeNow123!
# Generate a new session secret with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(24))"
SESSION_SECRET=wnSWRzNQ6sbSHbO2uBlCTy0IQPzY58PV

# ── Docker / Production ──────────────────────────────────────────────────────────
# Health check server port (engine container only — not exposed publicly)
HEALTH_PORT=8001
