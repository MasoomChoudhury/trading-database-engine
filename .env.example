# Upstox Credentials
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_ACCESS_TOKEN=your_access_token_here

# Local TimescaleDB Credentials (STRICTLY REQUIRED FOR LOCAL CACHING)
# IMPORTANT: DO NOT USE "password" - USE A LONG RANDOM STRING
TIMESCALEDB_USER=your_secure_user_here
TIMESCALEDB_PASSWORD=your_very_strong_password_here
TIMESCALEDB_NAME=trading_db
TIMESCALEDB_HOST=127.0.0.1
TIMESCALEDB_PORT=5432

# Supabase Credentials
SUPABASE_URL=https://your-project-url.supabase.co
SUPABASE_KEY=your_supabase_anon_key_or_service_role_key

# Web Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=strongpassword
SESSION_SECRET=generate_a_random_string_here
UPSTOX_REDIRECT_URI=https://database.masoomchoudhury.com/auth/upstox-callback
